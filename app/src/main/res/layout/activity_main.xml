<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/red_primary"
            android:layout_marginTop="48dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stopped"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginTop="16dp" />

        <!-- BPM Display -->
        <TextView
            android:id="@+id/tvBpm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="80sp"
            android:textStyle="bold"
            android:textColor="@color/red_primary"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BPM"
            android:textSize="18sp"
            android:textColor="#999999"
            android:layout_marginTop="4dp" />

        <!-- Start / Stop Button -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:text="@string/start_monitoring"
            android:textSize="16sp"
            android:layout_marginTop="32dp"
            android:textColor="@color/white"
            android:backgroundTint="@color/red_primary" />

        <!-- Overlay Size Control -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/overlay_size_label"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/size_small"
                android:textSize="12sp"
                android:textColor="#999999" />

            <SeekBar
                android:id="@+id/seekBarSize"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="12dp"
                android:min="0"
                android:max="36"
                android:progress="8" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/size_large"
                android:textSize="12sp"
                android:textColor="#999999" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSizePreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❤️ 142 bpm"
            android:textStyle="bold"
            android:textColor="@color/red_primary"
            android:layout_marginTop="8dp" />

        <!-- Instructions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/instructions"
            android:textSize="14sp"
            android:textColor="#666666"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>
